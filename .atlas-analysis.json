  "keyFeatures": [
    "Real-time water quality monitoring with IoT meter devices",
    "Multi-workspace collaboration with role-based access control",
    "Advanced data analysis (averages, predictions, correlations)",
    "AI-powered chat for analysis insights using OpenAI",
    "Customizable alert system with email and push notifications",
    "GitHub OAuth authentication and JWT-based authorization",
    "Weather data integration for environmental context",
    "Prometheus metrics for system monitoring",
    "WebSocket support for real-time updates",
    "PDF report generation with charts and visualizations"
  ],
  "publicApiSurface": [
    "POST /auth/login/",
    "POST /auth/register/",
    "GET /auth/github/login",
    "POST /auth/request-password-reset/",
    "GET /workspaces/",
    "POST /workspaces/",
    "GET /workspaces/{id}",
    "POST /workspaces/{id}/guest/",
    "GET /meters/{id_workspace}/",
