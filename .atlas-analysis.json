    "POST /meters/{id_workspace}/pair/{id_meter}/",
    "GET /meters/records/{id_workspace}/{id_meter}/",
    "GET /meters/{id_workspace}/weather/{id_meter}/",
    "GET /alerts/",
    "POST /alerts/",
    "GET /alerts/notifications/",
    "PUT /alerts/notifications/status/{notification_id}/",
    "POST /analysis/average/",
    "POST /analysis/correlation/",
    "POST /analysis/prediction/",
    "POST /analysis/report/",
    "POST /analysis/ai/{analysis_id}/chat",
